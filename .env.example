# ─── Database ───────────────────────────────────────────────────────────────
POSTGRES_USER=abituriyent
POSTGRES_PASSWORD=abituriyent_secret
POSTGRES_DB=abituriyent_db

# Full async URL used by FastAPI/SQLAlchemy
DATABASE_URL=postgresql+asyncpg://abituriyent:abituriyent_secret@localhost:5432/abituriyent_db

# Sync URL used by Alembic migrations
DATABASE_SYNC_URL=postgresql+psycopg2://abituriyent:abituriyent_secret@localhost:5432/abituriyent_db

# ─── Auth / Security ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=changeme_in_production_use_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Backend ─────────────────────────────────────────────────────────────────
ENVIRONMENT=development
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000

# ─── Frontend (Next.js public vars) ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Firebase (OPTIONAL — Google / Email sign-in only) ───────────────────────
# Leave these blank to run without Firebase. The landing page "Demo" button
# (POST /auth/demo) lets visitors enter the full platform without any login.
# Only Google & email sign-in require these keys.
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ─── AI — Google Gemini (aistudio.google.com) ────────────────────────────────
# Used for: AI Tutor (2.5 Flash), Appeals (2.5 Pro), Hints (2.0 Flash Lite), Embeddings
GEMINI_API_KEY=your-gemini-api-key-here

# Model overrides (optional — defaults set in config.py)
# GEMINI_TUTOR_MODEL=gemini-2.5-flash
# GEMINI_APPEALS_MODEL=gemini-2.5-pro
# GEMINI_HINT_MODEL=gemini-2.0-flash-lite
# GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# ─── Optional: Redis (future caching / rate limiting) ────────────────────────
# REDIS_URL=redis://localhost:6379/0
